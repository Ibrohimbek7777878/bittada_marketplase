# ============================================================================
# BITTADA — environment template. Copy to `.env` and fill in real values.
# Never commit `.env`. Real secrets go to a vault (1Password / Doppler / SOPS).
# ============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000
DJANGO_TIME_ZONE=Asia/Tashkent
DJANGO_LANGUAGE_CODE=uz

# --- Database (PostgreSQL) ---
POSTGRES_DB=bittada
POSTGRES_USER=bittada
POSTGRES_PASSWORD=bittada
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=bittada
S3_SECRET_KEY=bittada-secret
S3_BUCKET_PUBLIC=bittada-public
S3_BUCKET_PRIVATE=bittada-private
S3_REGION=us-east-1

# --- JWT ---
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=14

# --- Auth providers (toggleable from admin; secrets here) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
SMS_PROVIDER=eskiz
SMS_API_KEY=
SMS_FROM=Bittada

# --- Email ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL="Bittada <noreply@bittada.uz>"

# --- AI text helper (optional) ---
AI_TEXT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev

# --- Frontend ---
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_BASE=http://localhost:8000/api/v1
